{
  "openapi": "3.1.0",
  "info": {
    "title": "Bike Rental API",
    "version": "0.1.0"
  },
  "paths": {
    "/rentals": {
      "post": {
        "summary": "Create Rental Endpoint",
        "operationId": "create_rental_endpoint_rentals_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRentalRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RentalResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment Required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Endpoint",
        "operationId": "health_endpoint_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateRentalRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid",
            "title": "User Id"
          },
          "station_id": {
            "type": "string",
            "format": "uuid",
            "title": "Station Id"
          },
          "bicycle_ids": {
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "type": "array",
            "minItems": 1,
            "title": "Bicycle Ids"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "user_id",
          "station_id",
          "bicycle_ids"
        ],
        "title": "CreateRentalRequest",
        "description": "Body of ``POST /rentals`` (HU-05/HU-07).\n\nPydantic validates UUID syntax (malformed -> 422) and enforces a non-empty\nbicycle list at the edge (``min_length=1``); the domain still raises\n``EmptyRentalError`` as a safety net. ``extra='forbid'`` rejects unknown\nfields at the boundary."
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error"
          },
          "detail": {
            "type": "string",
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "error",
          "detail"
        ],
        "title": "ErrorResponse",
        "description": "Uniform error body. ``error`` is the stable domain error name; ``detail``\nis a human-readable message — never a stack trace."
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "description": "Body of ``GET /health`` (HU-08)."
      },
      "RentalResponse": {
        "properties": {
          "rental_id": {
            "type": "string",
            "format": "uuid",
            "title": "Rental Id"
          },
          "payment_id": {
            "type": "string",
            "format": "uuid",
            "title": "Payment Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "rental_id",
          "payment_id",
          "status"
        ],
        "title": "RentalResponse",
        "description": "Success body of ``POST /rentals`` (201)."
      }
    }
  }
}