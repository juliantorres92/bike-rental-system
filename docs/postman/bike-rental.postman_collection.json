{
  "info": {
    "name": "Bike Rental API — CreateRental (E-02)",
    "description": "Colección para el adaptador HTTP de referencia (FastAPI) del caso de uso 'crear renta multi-bicicleta'. Los ids del camino feliz son los sembrados de forma determinista por la raíz de composición en memoria, así que funcionan contra el servidor recién levantado. NOTA: 'Crear renta (feliz)' muta el estado (deja las bicis rentadas); para repetirlo, reinicia el servidor.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "station_id", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "user_id", "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "bike_1", "value": "a0000000-0000-0000-0000-000000000001" },
    { "key": "bike_2", "value": "a0000000-0000-0000-0000-000000000002" },
    { "key": "bike_3", "value": "a0000000-0000-0000-0000-000000000003" }
  ],
  "item": [
    {
      "name": "Health check (200)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
          ] }
        }
      ]
    },
    {
      "name": "Validación: bicycle_ids vacío (422)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": []\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "type": "text/javascript", "exec": [
            "pm.test('422 Unprocessable Entity', () => pm.response.to.have.status(422));"
          ] }
        }
      ]
    },
    {
      "name": "Conflicto: bicicletas duplicadas (422)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": [\"{{bike_1}}\", \"{{bike_1}}\"]\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "type": "text/javascript", "exec": [
            "pm.test('422', () => pm.response.to.have.status(422));",
            "pm.test('error DuplicateBicycleError', () => pm.expect(pm.response.json().error).to.eql('DuplicateBicycleError'));"
          ] }
        }
      ]
    },
    {
      "name": "No encontrada: bicicleta inexistente (404)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": [\"99999999-9999-9999-9999-999999999999\"]\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "type": "text/javascript", "exec": [
            "pm.test('404 Not Found', () => pm.response.to.have.status(404));",
            "pm.test('error BicycleNotFoundError', () => pm.expect(pm.response.json().error).to.eql('BicycleNotFoundError'));"
          ] }
        }
      ]
    },
    {
      "name": "Crear renta (feliz, 201) — muta estado",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": [\"{{bike_1}}\", \"{{bike_2}}\"]\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "type": "text/javascript", "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.test('renta activa con ids', () => {",
            "  const b = pm.response.json();",
            "  pm.expect(b.status).to.eql('activa');",
            "  pm.expect(b.rental_id).to.be.a('string');",
            "  pm.expect(b.payment_id).to.be.a('string');",
            "});"
          ] }
        }
      ]
    }
  ]
}
