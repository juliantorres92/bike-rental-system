{
  "info": {
    "name": "Bike Rental API — CreateRental (E-02) + Consultas (E-03)",
    "description": "Colección del adaptador HTTP de referencia (FastAPI). Endpoints de escritura (POST /rentals) y de lectura (GET /stations, /stations/{id}/bicycles, /rentals/{id}). Los ids del camino feliz son deterministas (sembrados por la raíz de composición en memoria), así que funcionan contra el servidor recién levantado. NOTA: 'Crear renta (feliz)' muta el estado; para repetirlo, reinicia el servidor. Esa request captura el rental_id en una variable para consultarlo luego.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "station_id", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "user_id", "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "bike_1", "value": "a0000000-0000-0000-0000-000000000001" },
    { "key": "bike_2", "value": "a0000000-0000-0000-0000-000000000002" },
    { "key": "bike_3", "value": "a0000000-0000-0000-0000-000000000003" },
    { "key": "rental_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health check (200)",
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('200 OK', () => pm.response.to.have.status(200));",
        "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
      ] } }]
    },
    {
      "name": "Listar estaciones (200) — descubrir ids",
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{base_url}}/stations", "host": ["{{base_url}}"], "path": ["stations"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('200 OK', () => pm.response.to.have.status(200));",
        "const list = pm.response.json();",
        "pm.test('lista de estaciones', () => pm.expect(list).to.be.an('array'));",
        "if (list.length) { pm.collectionVariables.set('station_id', list[0].id); }"
      ] } }]
    },
    {
      "name": "Bicicletas de una estación (200)",
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{base_url}}/stations/{{station_id}}/bicycles?available=true", "host": ["{{base_url}}"], "path": ["stations", "{{station_id}}", "bicycles"], "query": [{ "key": "available", "value": "true" }] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('200 OK', () => pm.response.to.have.status(200));",
        "pm.test('array de bicicletas', () => pm.expect(pm.response.json()).to.be.an('array'));"
      ] } }]
    },
    {
      "name": "Bicicletas: estación inexistente (404)",
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{base_url}}/stations/99999999-9999-9999-9999-999999999999/bicycles", "host": ["{{base_url}}"], "path": ["stations", "99999999-9999-9999-9999-999999999999", "bicycles"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('404', () => pm.response.to.have.status(404));",
        "pm.test('error StationNotFoundError', () => pm.expect(pm.response.json().error).to.eql('StationNotFoundError'));"
      ] } }]
    },
    {
      "name": "Validación: bicycle_ids vacío (422)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": []\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('422', () => pm.response.to.have.status(422));"
      ] } }]
    },
    {
      "name": "Conflicto: bicicletas duplicadas (422)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": [\"{{bike_1}}\", \"{{bike_1}}\"]\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('422', () => pm.response.to.have.status(422));",
        "pm.test('error DuplicateBicycleError', () => pm.expect(pm.response.json().error).to.eql('DuplicateBicycleError'));"
      ] } }]
    },
    {
      "name": "No encontrada: bicicleta inexistente (404)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": [\"99999999-9999-9999-9999-999999999999\"]\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('404', () => pm.response.to.have.status(404));",
        "pm.test('error BicycleNotFoundError', () => pm.expect(pm.response.json().error).to.eql('BicycleNotFoundError'));"
      ] } }]
    },
    {
      "name": "Crear renta (feliz, 201) — muta estado y captura rental_id",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"station_id\": \"{{station_id}}\",\n  \"bicycle_ids\": [\"{{bike_1}}\", \"{{bike_2}}\"]\n}" },
        "url": { "raw": "{{base_url}}/rentals", "host": ["{{base_url}}"], "path": ["rentals"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('201 Created', () => pm.response.to.have.status(201));",
        "const b = pm.response.json();",
        "pm.test('renta activa con ids', () => {",
        "  pm.expect(b.status).to.eql('activa');",
        "  pm.expect(b.rental_id).to.be.a('string');",
        "  pm.expect(b.payment_id).to.be.a('string');",
        "});",
        "if (b.rental_id) { pm.collectionVariables.set('rental_id', b.rental_id); }"
      ] } }]
    },
    {
      "name": "Consultar renta por id (200) — requiere crear renta antes",
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{base_url}}/rentals/{{rental_id}}", "host": ["{{base_url}}"], "path": ["rentals", "{{rental_id}}"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('200 OK', () => pm.response.to.have.status(200));",
        "const r = pm.response.json();",
        "pm.test('renta con items', () => {",
        "  pm.expect(r.status).to.eql('activa');",
        "  pm.expect(r.items).to.be.an('array');",
        "});"
      ] } }]
    },
    {
      "name": "Consultar renta inexistente (404)",
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{base_url}}/rentals/99999999-9999-9999-9999-999999999999", "host": ["{{base_url}}"], "path": ["rentals", "99999999-9999-9999-9999-999999999999"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('404', () => pm.response.to.have.status(404));",
        "pm.test('error RentalNotFoundError', () => pm.expect(pm.response.json().error).to.eql('RentalNotFoundError'));"
      ] } }]
    }
  ]
}
